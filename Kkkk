st.set_page_config(layout="wide")
st.title("📅 Programme Mensuel d'Hygiène - Site 4 Hectares")

# Configuration
agents = ["Agent 1", "Agent 2", "Agent 3", "Agent 4", "Agent 5", "Agent 6"]
zones = ["Zone A", "Zone B", "Zone C", "Zone D", "Zone E", "Zone F"]
jours = [f"Jour {i}" for i in range(1, 25)]

# Génération des données
planning = []
for j in range(len(jours)):
    jour_rotation = [zones[(i + j) % len(zones)] for i in range(len(agents))]
    planning.append(jour_rotation)

df = pd.DataFrame(np.array(planning).T, index=agents, columns=jours)

# Interface Streamlit
st.sidebar.header("Filtres")
selection_agent = st.sidebar.multiselect("Filtrer par Agent", options=agents, default=agents)

# Affichage du tableau
st.subheader("Planning de rotation des agents")
st.dataframe(df.loc[selection_agent], use_container_width=True)

# Exportation
st.download_button(
    label="Télécharger le planning en CSV",
    data=df.to_csv().encode('utf-8'),
    file_name='programme_hygiene.csv',
    mime='text/csv',
)
